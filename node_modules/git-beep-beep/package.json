{
  "name": "git-beep-beep",
  "version": "1.0.0",
  "description": "Hear your commits — plays sound effects on git push and commit events",
  "type": "module",
  "bin": {
    "beep-beep": "bin/beep-beep.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "standard-version"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^17.6.0",
    "prettier": "^3.4.2",
    "standard-version": "^9.5.0",
    "vitest": "^2.1.8"
  },
  "files": [
    "bin/",
    "src/",
    "sounds/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "git",
    "hooks",
    "sound",
    "push",
    "commit",
    "audio",
    "notification"
  ],
  "license": "MIT"
}
